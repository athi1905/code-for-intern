def is_palindrome(text):
    
    cleaned_text = text.replace(" ", "").lower()

    
    if cleaned_text == cleaned_text[::-1]:
        return True
    else:
        return False



word = input("Enter a word or phrase: ")


if is_palindrome(word):
    print("It is a palindrome.")
else:
    print("It is not a palindrome.")
