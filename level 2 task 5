file = open("sample.txt", "r")

text = file.read()

file.close()

text = text.lower()

words = text.split()

word_count = {}

for word in words:

    if word in word_count:
        word_count[word] += 1

    else:
        word_count[word] = 1

print("Word Occurrences:\n")

for word in sorted(word_count):
    print(word, ":", word_count[word])
